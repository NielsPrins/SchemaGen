{
  "name": "@nielsprins/schemagen",
  "version": "1.0.1",
  "description": "A TypeScript CLI starter for SchemaGen.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc && tsx src/index.ts --editor --dir examples/drizzle-orm",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev:mees": "tsx watch src/utils/temp.ts"
  },
  "bin": {
    "schemagen": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "cli",
    "typescript",
    "schema"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/plantuml-encoder": "^1.4.2",
    "dotenv": "^17.3.1",
    "prettier": "3.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "ai": "^6.0.141",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "plantuml-encoder": "^1.4.0",
    "zod": "^4.3.6"
  }
}
